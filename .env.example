# Frontend
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_XXXX
CLERK_SECRET_KEY=sk_test_XXXX

# Backend
NOVAREEL_AUTH_DISABLED=true
NOVAREEL_STORAGE_BACKEND=local
NOVAREEL_QUEUE_BACKEND=poll
NOVAREEL_USE_MOCK_AI=true
NOVAREEL_LOCAL_DATA_DIR=services/backend/data
NOVAREEL_PUBLIC_API_BASE_URL=http://localhost:8000
NOVAREEL_MONTHLY_VIDEO_QUOTA=10
NOVAREEL_MAX_ASSETS_PER_PROJECT=12
NOVAREEL_MAX_ASSET_FILE_SIZE_BYTES=10000000
NOVAREEL_ALLOWED_ASSET_CONTENT_TYPES=["image/jpeg","image/png","image/webp"]
NOVAREEL_CORS_ORIGINS=["http://localhost:3000"]
NOVAREEL_ADMIN_USER_IDS=["beta-user"]
NOVAREEL_WORKER_MAX_ATTEMPTS=3
NOVAREEL_WORKER_RETRY_BACKOFF_SECONDS=20

# TTS Providers
NOVAREEL_ELEVENLABS_API_KEY=

# Stock Footage (Pexels)
NOVAREEL_PEXELS_API_KEY=

# AWS (for non-local backends)
NOVAREEL_AWS_REGION=us-east-1
NOVAREEL_S3_BUCKET_NAME=novareel-phase1
NOVAREEL_DYNAMODB_PROJECTS_TABLE=novareel-projects
NOVAREEL_DYNAMODB_JOBS_TABLE=novareel-jobs
NOVAREEL_DYNAMODB_RESULTS_TABLE=novareel-results
NOVAREEL_DYNAMODB_USAGE_TABLE=novareel-usage
NOVAREEL_DYNAMODB_ANALYTICS_TABLE=novareel-analytics
NOVAREEL_SQS_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/123456789012/novareel-jobs

# Phase 3 — Brand Kit & Asset Library
NOVAREEL_MAX_LIBRARY_ASSETS=50
NOVAREEL_MAX_LIBRARY_FILE_SIZE_BYTES=52428800

# Phase 3 — Social Media Distribution
NOVAREEL_GOOGLE_CLIENT_ID=
NOVAREEL_GOOGLE_CLIENT_SECRET=
NOVAREEL_SOCIAL_REDIRECT_BASE_URL=http://localhost:8000
NOVAREEL_ENCRYPTION_KEY=

# Phase 3 — Performance & Scalability
NOVAREEL_WORKER_MODE=polling
NOVAREEL_CELERY_BROKER_URL=redis://localhost:6379/0
NOVAREEL_FFMPEG_PRESET=medium
NOVAREEL_CDN_BASE_URL=
