# ─────────────────────────────────────────────
# NovaReel — Production Environment Variables
# ─────────────────────────────────────────────
# Copy to .env.production and fill in real values.
# Secrets should be stored in AWS Secrets Manager (injected via ECS task definition).

# ── Frontend ────────────────────────────────
NEXT_PUBLIC_APP_URL=https://novareel.example.com
NEXT_PUBLIC_API_BASE_URL=https://api.novareel.example.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_XXXX
CLERK_SECRET_KEY=sk_live_XXXX

# ── Core ────────────────────────────────────
NOVAREEL_ENV=production
NOVAREEL_AUTH_DISABLED=false
NOVAREEL_USE_MOCK_AI=false

# ── Storage (AWS) ───────────────────────────
NOVAREEL_STORAGE_BACKEND=dynamodb
NOVAREEL_QUEUE_BACKEND=sqs
NOVAREEL_AWS_REGION=us-east-1

# ── DynamoDB Tables ─────────────────────────
NOVAREEL_DYNAMODB_PROJECTS_TABLE=novareel-production-projects
NOVAREEL_DYNAMODB_JOBS_TABLE=novareel-production-jobs
NOVAREEL_DYNAMODB_RESULTS_TABLE=novareel-production-results
NOVAREEL_DYNAMODB_USAGE_TABLE=novareel-production-usage
NOVAREEL_DYNAMODB_ANALYTICS_TABLE=novareel-production-analytics

# ── S3 ──────────────────────────────────────
NOVAREEL_S3_BUCKET_NAME=novareel-production-assets-ACCOUNT_ID

# ── SQS ─────────────────────────────────────
NOVAREEL_SQS_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/ACCOUNT_ID/novareel-production-jobs

# ── CDN ─────────────────────────────────────
NOVAREEL_CDN_BASE_URL=https://d1234abcdef.cloudfront.net
NOVAREEL_PUBLIC_API_BASE_URL=https://api.novareel.example.com

# ── CORS ────────────────────────────────────
NOVAREEL_CORS_ORIGINS=["https://novareel.example.com"]
NOVAREEL_ADMIN_USER_IDS=["admin-user-id"]

# ── Bedrock Models ──────────────────────────
NOVAREEL_BEDROCK_MODEL_SCRIPT=amazon.nova-lite-v1:0
NOVAREEL_BEDROCK_MODEL_ORCHESTRATOR=amazon.nova-pro-v1:0
NOVAREEL_BEDROCK_MODEL_VOICE=amazon.nova-sonic-v1:0
NOVAREEL_BEDROCK_MODEL_IMAGE=amazon.nova-canvas-v1:0

# ── TTS ─────────────────────────────────────
NOVAREEL_ELEVENLABS_API_KEY=

# ── Stock Footage ───────────────────────────
NOVAREEL_PEXELS_API_KEY=

# ── Quotas ──────────────────────────────────
NOVAREEL_MONTHLY_VIDEO_QUOTA=10
NOVAREEL_MAX_ASSETS_PER_PROJECT=12
NOVAREEL_MAX_ASSET_FILE_SIZE_BYTES=10000000

# ── Worker ──────────────────────────────────
NOVAREEL_WORKER_MODE=polling
NOVAREEL_WORKER_MAX_ATTEMPTS=3
NOVAREEL_WORKER_RETRY_BACKOFF_SECONDS=20
NOVAREEL_FFMPEG_PRESET=medium

# ── Social Media (Phase 3) ──────────────────
NOVAREEL_GOOGLE_CLIENT_ID=
NOVAREEL_GOOGLE_CLIENT_SECRET=
NOVAREEL_SOCIAL_REDIRECT_BASE_URL=https://api.novareel.example.com
NOVAREEL_ENCRYPTION_KEY=

# ── Feature Flags ───────────────────────────
NOVAREEL_USE_EDITING_FRAMEWORK=false
NOVAREEL_USE_VISION_DIRECTOR=true
NOVAREEL_USE_AGENTIC_ORCHESTRATOR=true
